NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production guard:
# - Vercel production deploys are detected with VERCEL_ENV=production.
# - For local production-like checks, set NATIVE_MINUTE_PRODUCTION_GUARD=1.
# - Production expects VOICE_PROVIDER=elevenlabs, TRANSCRIPTION_PROVIDER=openai,
#   PRONUNCIATION_PROVIDER=azure, and SCRIPT_GENERATION_PROVIDER=openai.
# - Before DB-backed quota enforcement, production launch mode must be private_beta
#   or small_cohort. public_free is intentionally blocked by production preflight.
NATIVE_MINUTE_ENV=
NATIVE_MINUTE_PRODUCTION_GUARD=
NATIVE_MINUTE_LAUNCH_MODE=
# Emergency cost kill switches. Set to 1 only when pausing that paid surface.
NATIVE_MINUTE_DISABLE_OPENAI=
NATIVE_MINUTE_DISABLE_AZURE=
NATIVE_MINUTE_DISABLE_ELEVENLABS=
# Pauses new uploads. Account deletion Storage cleanup still requires the separate destructive guard below.
NATIVE_MINUTE_DISABLE_STORAGE_UPLOADS=
# Timing logs are enabled automatically outside production.
# In production, set to 1 only for an intentional short measurement window.
NATIVE_MINUTE_ENABLE_TIMING=0
# Destructive account deletion is off by default.
# Set to 1 only for an intentional support/admin cleanup run with a disposable proof first.
NATIVE_MINUTE_ENABLE_ACCOUNT_DELETION_DESTRUCTIVE=
VOICE_PROVIDER=mock
# Script Studio draft generation defaults to mock. Use openai only for an intentional live smoke.
SCRIPT_GENERATION_PROVIDER=mock
TRANSCRIPTION_PROVIDER=mock
# Required only when SCRIPT_GENERATION_PROVIDER=openai, VOICE_PROVIDER=openai, or TRANSCRIPTION_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_VOICE_MODEL=gpt-4o-mini-tts
OPENAI_SCRIPT_GENERATION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
PRONUNCIATION_PROVIDER=mock
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
E2E_TEST_SECRET=
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
