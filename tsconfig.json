{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next-e2e-3204/types/**/*.ts",
    ".next-e2e-3201/types/**/*.ts",
    ".next-e2e-3200/types/**/*.ts",
    ".next-css-debug/types/**/*.ts",
    ".next-e2e-3100/types/**/*.ts",
    ".next-s5-smoke/types/**/*.ts",
    ".next-e2e-3216/types/**/*.ts",
    ".next-e2e-3217/types/**/*.ts",
    ".next-e2e-3218/types/**/*.ts",
    ".next-e2e-3219/types/**/*.ts",
    ".next-e2e-3221/types/**/*.ts",
    ".next-e2e-3222/types/**/*.ts",
    ".next-e2e-3223/types/**/*.ts",
    ".next-e2e-3224/types/**/*.ts",
    ".next-e2e-3225/types/**/*.ts",
    ".next-e2e-3226/types/**/*.ts",
    ".next-e2e-3227/types/**/*.ts",
    ".next-e2e-3230/types/**/*.ts",
    ".next-e2e-3231/types/**/*.ts",
    ".next-e2e-3232/types/**/*.ts",
    ".next-dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
